# ─── Clerk ────────────────────────────────────────────────────────────────────
# Found in the Clerk dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_
# Secret used to verify incoming Clerk webhook payloads
CLERK_WEBHOOK_SECRET=whsec_

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Full Atlas connection string (includes credentials)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Database name (e.g. "production" or "staging")
MONGODB_DB=production

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# The S3 bucket used for content uploads and AI-generated images
AWS_S3_BUCKET=your-bucket-name
# Legacy alias — keep in sync with AWS_S3_BUCKET
AWS_BUCKET=your-bucket-name

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Secret key — server-side only
STRIPE_SECRET_KEY=sk_test_
# Publishable key — safe to expose client-side
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
# Product/price IDs from the Stripe dashboard
STRIPE_DEVICE_PRODUCT_ID=prod_
STRIPE_SUBSCRIPTION_PRODUCT_ID=prod_
STRIPE_SUBSCRIPTION_PRICE_ID=price_
# Device price in cents (e.g. 4999 = $49.99)
NEXT_PUBLIC_DEVICE_PRICE=4999
# When true, the device is always charged; when false, the trial disclaimer is shown
NEXT_DEVICE_ALWAYS_CHARGE=false
# When true, the Generate with AI button is shown on the Content Library
NEXT_SHOW_AI_CONTENT_CREATION=false

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Used for AI content generation (gpt-image-1)
OPENAI_API_KEY=sk-

# ─── Trigger.dev ──────────────────────────────────────────────────────────────
# Found in the Trigger.dev dashboard → API Keys
TRIGGER_SECRET_KEY=tr_

# ─── Google ───────────────────────────────────────────────────────────────────
# Used for Places autocomplete in the onboarding location step
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# ─── Socket Server ────────────────────────────────────────────────────────────
# Base URL of the mammoth-socket-server (no trailing slash)
SOCKET_SERVER_URL=https://mammoth-socket-server.fly.dev
# API_TOKEN value set in the socket server's environment
SOCKET_SERVER_API_TOKEN=

# ─── CETV Internal ────────────────────────────────────────────────────────────
# MongoDB ObjectId of the CETV network document — assigned per environment
CETV_NETWORK_ID=
